# Supabase project (Project Settings > API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Leave empty for local dev (the Vite proxy forwards /api to the local Worker).
# In production set this to the deployed Worker URL, e.g. https://weeklog-worker.YOURNAME.workers.dev
VITE_API_BASE=
