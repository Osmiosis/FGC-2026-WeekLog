# Better Auth + Google OAuth (see docs/better-auth-google-setup.md).
# Leave both empty for local dev if you don't need to test sign-in (the login wall
# shows a "not configured" state instead of throwing).

# The deployed Worker origin. Empty locally lets the Vite dev proxy forward
# /api to the local Worker instead.
VITE_API_BASE=https://weeklog-worker.fgcworker.workers.dev

# Google OAuth Web client ID (Google Cloud Console > APIs & Services > Credentials).
# Must match the client whose Authorized JavaScript origins include this app's
# origin(s) and whose Authorized redirect URI is
# {VITE_API_BASE}/api/auth/callback/google.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
